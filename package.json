{
  "expo": {
    "name": "AxiosPrimus",
    "slug": "AxiosPrimus",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.axiosprimus"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.axiosprimus"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-font"
    ],
    "extra": {
      "eas": {
        "projectId": "b1de4ab5-a625-4a92-837a-c87c32e7e8b1"
      }
    }
  },
  "dependencies": {
    "@firebase/auth": "^1.8.1",
    "@firebase/firestore": "^4.7.5",
    "@react-native-async-storage/async-storage": "^1.24.0",
    "@react-native-firebase/app": "^20.5.0",
    "@react-native-firebase/messaging": "^20.5.0",
    "@react-native-picker/picker": "^2.11.0",
    "@react-navigation/bottom-tabs": "^7.2.0",
    "@react-navigation/drawer": "^7.1.1",
    "@react-navigation/material-top-tabs": "^7.1.0",
    "@react-navigation/native": "^7.0.14",
    "@react-navigation/native-stack": "^7.2.0",
    "@react-navigation/stack": "^7.1.1",
    "d3-color": "^3.1.0",
    "expo": "^52.0.21",
    "expo-document-picker": "^13.0.1",
    "expo-image-picker": "^16.0.3",
    "expo-linear-gradient": "^14.0.2",
    "firebase": "^11.2.0",
    "react-native-animatable": "^1.4.0",
    "react-native-chart-kit": "^6.12.0",
    "react-native-circular-progress": "^1.4.1",
    "react-native-fast-image": "^8.6.3",
    "react-native-gesture-handler": "~2.20.2",
    "react-native-get-random-values": "^1.11.0",
    "react-native-image-picker": "^7.2.3",
    "react-native-linear-gradient": "^2.8.3",
    "react-native-progress": "^5.0.1",
    "react-native-reanimated": "^3.16.6",
    "react-native-safe-area-context": "^4.14.1",
    "react-native-screens": "~4.4.0",
    "react-native-shimmer-placeholder": "^2.0.9",
    "react-native-svg": "^7.2.1",
    "react-native-svg-charts": "^5.4.0",
    "react-native-tab-view": "^4.0.5",
    "react-native-vector-icons": "^10.2.0",
    "victory-native": "^41.16.0"
  },
  "devDependencies": {
    "@types/react-native-svg-charts": "^5.0.16",
    "@types/react-navigation": "^3.0.8",
    "typescript": "^5.3.3"
  }
}
